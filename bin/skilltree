#!/usr/bin/env node

// Bin shim: detects platform/arch, finds the right binary, and executes it.

import { execFileSync } from "node:child_process";
import { createRequire } from "node:module";
import { join, dirname } from "node:path";

const require = createRequire(import.meta.url);

const PLATFORMS = {
  "darwin-arm64": "@imarios/skilltree-cli-darwin-arm64",
  "darwin-x64": "@imarios/skilltree-cli-darwin-x64",
  "linux-x64": "@imarios/skilltree-cli-linux-x64",
  "linux-arm64": "@imarios/skilltree-cli-linux-arm64",
};

const platformKey = `${process.platform}-${process.arch}`;
const packageName = PLATFORMS[platformKey];

if (!packageName) {
  console.error(
    `skilltree: unsupported platform ${platformKey}\n` +
    `Supported: ${Object.keys(PLATFORMS).join(", ")}`
  );
  process.exit(1);
}

let binPath;
try {
  // Resolve the binary from the platform-specific package
  const pkgPath = require.resolve(`${packageName}/package.json`);
  binPath = join(dirname(pkgPath), "bin", "skilltree");
} catch {
  console.error(
    `skilltree: could not find package "${packageName}".\n` +
    `This usually means the optional dependency was not installed.\n` +
    `Try reinstalling: npm install skilltree-pm`
  );
  process.exit(1);
}

// Forward all arguments to the real binary
try {
  execFileSync(binPath, process.argv.slice(2), {
    stdio: "inherit",
    env: process.env,
  });
} catch (e) {
  // execFileSync throws on non-zero exit. Forward the exit code.
  process.exit(e.status ?? 1);
}
