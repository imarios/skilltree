{
  "name": "skilltree-pm",
  "version": "0.19.0",
  "description": "Dependency manager for AI agent skills",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imarios/skilltree.git"
  },
  "homepage": "https://github.com/imarios/skilltree#readme",
  "bugs": {
    "url": "https://github.com/imarios/skilltree/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "skills",
    "agents",
    "dependency-manager",
    "claude",
    "skill-md"
  ],
  "bin": {
    "skilltree": "bin/skilltree"
  },
  "files": [
    "bin/skilltree",
    "README.md",
    "LICENSE"
  ],
  "optionalDependencies": {
    "@imarios/skilltree-cli-darwin-arm64": "0.10.0",
    "@imarios/skilltree-cli-darwin-x64": "0.10.0",
    "@imarios/skilltree-cli-linux-arm64": "0.10.0",
    "@imarios/skilltree-cli-linux-x64": "0.10.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format src/ tests/",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile src/cli.ts --outfile dist/skilltree",
    "build:npm": "./scripts/build-npm.sh",
    "publish:npm": "./scripts/publish-npm.sh",
    "prepublishOnly": "test -f bin/skilltree || (echo 'Error: Run bun run build:npm first' && exit 1)"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "simple-git": "^3.33.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
